ANTHROPIC_API_KEY=sk-ant-...

# Google Docs認証 - サービスアカウント方式（iPhoneからも動作）
# GCP Console でサービスアカウントを作成し、JSONキーをダウンロードして配置
# 参考: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service-account.json

# Google Docsの閲覧・編集権限を付与するGmailアドレス
# サービスアカウントが作成したDocは自動的にこのアドレスに共有される
USER_GOOGLE_EMAIL=your@gmail.com

# OAuth方式（デスクトップのみ）- サービスアカウントが使えない場合の代替
# デスクトップで以下を実行してtoken.jsonを生成:
# python -c "from integrations.google_docs import GoogleDocsClient; GoogleDocsClient().run_desktop_auth()"
GOOGLE_CREDENTIALS_PATH=credentials/credentials.json

OUTPUT_DIR=output
CLAUDE_MODEL=claude-sonnet-4-6
